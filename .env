# =============================================================================
# eduPro — Environment Variables
# Place this file in the same directory as manage.py
# NEVER commit this file to Git — add .env to your .gitignore
# =============================================================================


# =============================================================================
# DJANGO CORE
# =============================================================================

SECRET_KEY=django-insecure-change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost


# =============================================================================
# DATABASE
# =============================================================================

# Default: SQLite (fine for local dev)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/edupro


# =============================================================================
# EMAIL — Local Development
# Emails print to your terminal. No SMTP setup needed.
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@edupro.com


# =============================================================================
# EMAIL — Production (uncomment ONE block below and comment out the local block above)
# =============================================================================

# ── Gmail ────────────────────────────────────────────────────────────────────
# Requirements: Enable 2-Step Verification on your Google account, then go to:
# Google Account → Security → 2-Step Verification → App Passwords → Create one
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=youremail@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
# DEFAULT_FROM_EMAIL=eduPro <youremail@gmail.com>


# ── SendGrid (recommended — 100 free emails/day) ──────────────────────────────
# Sign up at https://sendgrid.com → Settings → API Keys → Create API Key
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key-here
# DEFAULT_FROM_EMAIL=eduPro <noreply@yourdomain.com>


# ── Brevo / Sendinblue (300 free emails/day) ──────────────────────────────────
# Sign up at https://brevo.com → SMTP & API → SMTP tab → copy credentials
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-brevo-login@email.com
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key
# DEFAULT_FROM_EMAIL=eduPro <noreply@yourdomain.com>


# ── Mailgun ───────────────────────────────────────────────────────────────────
# Sign up at https://mailgun.com → Sending → Domains → SMTP credentials
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=postmaster@mg.yourdomain.com
# EMAIL_HOST_PASSWORD=your-mailgun-smtp-password
# DEFAULT_FROM_EMAIL=eduPro <noreply@mg.yourdomain.com>
